#include <bits/stdc++.h>
#include<stdlib.h>

using namespace std;
    
    char board[3][3]={{'1','2','3'},{'4','5','6'},{'7','8','9'}};
    char turn = 'X';
    int row,column;
    bool draw= false;
    
   /* for(int i=0;i<3;i++) //rows
    for(int j=0;j<3;j++) //columns
    cout<<board[i][j]<<endl; */
    
    void display_board()
    { 
        system("clear");
    
    cout<<"\t\t Tic Tac Toe\n\n";
    cout<<"\t\tPLayer[X]\n";
    cout<<"\t\tPlayer[O]\n";
    cout<<"\t\t     |     |     \n\n";
    cout<<"\t\t  "<<board[0][0]<<"  |  "<<board[0][1]<<"  |  "<<board[0][2]<<"  \n\n";
    cout<<"\t\t     |     |     \n\n";
   
    cout<<"\t\t_____|_____|_____\n\n";
    cout<<"\t\t     |     |     \n\n";
    cout<<"\t\t  "<<board[1][0]<<"  |  "<<board[1][1]<<"  |  "<<board[1][2]<<"  \n\n";
    
  
    cout<<"\t\t_____|_____|_____\n\n";
    cout<<"\t\t     |     |     \n\n";
    cout<<"\t\t  "<<board[2][0]<<"  |  "<<board[2][1]<<"  |  "<<board[2][2]<<"  \n\n";
    
    }
    void player_turn(){
        int c;
        if(turn == 'X')
        cout<<"\n\tPlayer[X] turn :"<<endl;
        if(turn== 'O')
        cout<<"\n\tPlayer[O] turn :"<<endl;
    cin>>c;
    switch(c)
    {
        
        case 1:row=0;column=0;
        break;
       case 2:row=0;column=1;
        break;
       case 3:row=0;column=2;
        break;
       case 4:row=1;column=0;
        break;
       case 5:row=1;column=1;
        break;
       case 6:row=1;column=2;
        break;
       case 7:row=2;column=0;
        break;
       case 8:row=2;column=1;
        break;
       case 9:row=2;column=2;
        break;
       
            default:
        cout<<"Invalid choice"<<endl;
        break;
        
        
    } 
    if(turn =='X'){
        board[row][column]='X';
        turn ='O'; 
    }
    else
    if(turn =='O'){
        board[row][column]='O';
        turn ='X'; 
    }
}
    bool gameover(){
        //check win
        for(int i=0;i<3;i++)
        if(board[i][0]== board[i][1] && board[i][0]== board[i][2] || board[0][i]== board[1][i] && board[0][i]== board[2][i] )
        return false;
        
         if(board[0][0]== board[1][1] && board[0][0]== board[2][2] || board[0][2]== board[1][1] && board[0][2] == board[2][0] )
        return false;
        
        //if any box is not filled
        for(int i=0;i<3;i++)
        for(int j=0;j<3;j++)
        if(board[i][j]!= 'X'&& board[i][j] != 'O')
        return true;
        
        //drawgame
        draw =true;
        return false;
    }
    
    int main()
    {
        
    while(gameover())
    {
    display_board();
    player_turn();
    display_board();
    gameover();
    }
    
     if(turn =='X' && draw == false)
     cout<<"Congratulations!!!!!!!!Player[O]Wins"<<endl;
     else
     
     if(turn == 'O' && draw == false)
     cout<<"Congratulations!!!!!!!!Player[X]Wins"<<endl;
     
     else
     cout<<"GAME DRAW !! BETTER LUCK NEXT TIME "<<endl;
    
    }
